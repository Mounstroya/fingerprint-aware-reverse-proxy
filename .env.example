PORT=3099

# Upstream target the proxy forwards to
TARGET_BASE_URL=https://example-target.test
TARGET_PAGE_PATH=/app/
TARGET_API_PATH=/app/api

# Third-party widget/API this proxy relays and captures tokens from
THIRD_PARTY_API_BASE=https://api.third-party-verifier.test
THIRD_PARTY_PAGE_BASE=https://onboarding.third-party-verifier.test
TOKEN_ISSUING_PATH=/session/start

# Optional: override the User-Agent the proxy presents upstream
PROXY_USER_AGENT=

# Comma-separated list of browser origins allowed to call this proxy with
# credentials. Empty = same-origin only (no cross-origin browser calls).
ALLOWED_ORIGINS=

# Session cookie: set to "false" only for local http:// development.
COOKIE_SECURE=true
SESSION_TTL_MS=1800000

# Directory for per-session cookie jars. Defaults to a dedicated 0700
# folder under the OS tmpdir if unset.
COOKIE_DIR=

# Headers forwarded from the browser to THIRD_PARTY_API_BASE on
# /verify-api/*. Keep this an allowlist — never add "cookie" here.
VERIFY_FORWARD_HEADERS=content-type,accept,accept-language

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

MAX_CONCURRENT_CURL=20

LOG_LEVEL=info
