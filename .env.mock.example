# Points the proxy at mock/server.js (npm run mock) instead of a real
# upstream, so the whole flow runs end-to-end with no real credentials.
# Usage: cp .env.mock.example .env

PORT=3099

TARGET_BASE_URL=http://localhost:4000
TARGET_PAGE_PATH=/app/
TARGET_API_PATH=/app/api

THIRD_PARTY_API_BASE=http://localhost:4000
THIRD_PARTY_PAGE_BASE=http://localhost:4000
TOKEN_ISSUING_PATH=/session/start

PROXY_USER_AGENT=

ALLOWED_ORIGINS=
COOKIE_SECURE=false
SESSION_TTL_MS=1800000
COOKIE_DIR=

VERIFY_FORWARD_HEADERS=content-type,accept,accept-language

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

MAX_CONCURRENT_CURL=20

LOG_LEVEL=info
